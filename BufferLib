local BufferUtils = {}

local FireServer = Instance.new("RemoteEvent").FireServer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RemoteEvent = ReplicatedStorage:WaitForChild("###zzz###")

local BufferSize = 0
local BufferCapacity = 64
local CurrentBuffer = buffer.create(64)
local ObjectIndex = 0
local ObjectTable = table.create(16)
local IsProcessing = false

local function EnsureCapacity(needed)
    if BufferSize + needed > BufferCapacity then
        while BufferSize + needed > BufferCapacity do
            BufferCapacity = BufferCapacity * 2
        end
        local NewBuffer = buffer.create(BufferCapacity)
        buffer.copy(NewBuffer, 0, CurrentBuffer, 0, BufferSize)
        CurrentBuffer = NewBuffer
    end
end

game:GetService("RunService").Heartbeat:Connect(function()
    if BufferSize ~= 0 and not IsProcessing then
        IsProcessing = true
        local SendBuffer = buffer.create(BufferSize)
        buffer.copy(SendBuffer, 0, CurrentBuffer, 0, BufferSize)
        FireServer(RemoteEvent, SendBuffer, ObjectTable)
        BufferSize = 0
        BufferCapacity = 64
        CurrentBuffer = buffer.create(64)
        ObjectIndex = 0  
        table.clear(ObjectTable)
        IsProcessing = false
    end
end)

BufferUtils.WriteU8 = function(Value)
    EnsureCapacity(1)
    local pos = BufferSize
    BufferSize = BufferSize + 1
    buffer.writeu8(CurrentBuffer, pos, Value)
end

BufferUtils.WriteU16 = function(Value)
    EnsureCapacity(2)
    local pos = BufferSize
    BufferSize = BufferSize + 2
    buffer.writeu16(CurrentBuffer, pos, Value)
end

BufferUtils.WriteU32 = function(Value)
    EnsureCapacity(4)
    local pos = BufferSize
    BufferSize = BufferSize + 4
    buffer.writeu32(CurrentBuffer, pos, Value)
end

BufferUtils.WriteI8 = function(Value)
    EnsureCapacity(1)
    local pos = BufferSize
    BufferSize = BufferSize + 1
    buffer.writei8(CurrentBuffer, pos, Value)
end

BufferUtils.WriteI16 = function(Value)
    EnsureCapacity(2)
    local pos = BufferSize
    BufferSize = BufferSize + 2
    buffer.writei16(CurrentBuffer, pos, Value)
end

BufferUtils.WriteI32 = function(Value)
    EnsureCapacity(4)
    local pos = BufferSize
    BufferSize = BufferSize + 4
    buffer.writei32(CurrentBuffer, pos, Value)
end

BufferUtils.WriteF32 = function(Value)
    EnsureCapacity(4)
    local pos = BufferSize
    BufferSize = BufferSize + 4
    buffer.writef32(CurrentBuffer, pos, Value)
end

BufferUtils.WriteF64 = function(Value)
    EnsureCapacity(8)
    local pos = BufferSize
    BufferSize = BufferSize + 8
    buffer.writef64(CurrentBuffer, pos, Value)
end

BufferUtils.WriteString = function(Value)
    local len = string.len(Value)
    EnsureCapacity(2)
    local pos = BufferSize
    BufferSize = BufferSize + 2
    buffer.writeu16(CurrentBuffer, pos, len)
    EnsureCapacity(len)
    pos = BufferSize
    BufferSize = BufferSize + len
    buffer.writestring(CurrentBuffer, pos, Value, len)
end

BufferUtils.WriteObject = function(Value)
    EnsureCapacity(1)
    local pos = BufferSize
    BufferSize = BufferSize + 1
    local existing = table.find(ObjectTable, Value)
    if existing then
        buffer.writeu8(CurrentBuffer, pos, existing)
    else
        ObjectIndex = ObjectIndex + 1
        ObjectTable[ObjectIndex] = Value
        buffer.writeu8(CurrentBuffer, pos, ObjectIndex)
    end
end

BufferUtils.Flush = function()
    if BufferSize ~= 0 and not IsProcessing then
        IsProcessing = true
        local SendBuffer = buffer.create(BufferSize)
        buffer.copy(SendBuffer, 0, CurrentBuffer, 0, BufferSize)
        FireServer(RemoteEvent, SendBuffer, ObjectTable)
        BufferSize = 0
        BufferCapacity = 64
        CurrentBuffer = buffer.create(64)
        ObjectIndex = 0
        table.clear(ObjectTable)
        IsProcessing = false
    end
end
return BufferUtils
